# Force LF line endings for shell scripts and Python files so they run in WSL.
*.sh text eol=lf
*.py text eol=lf
src/mypeople/mp text eol=lf

# PowerShell files stay CRLF-friendly.
*.ps1 text eol=crlf

# Markdown and YAML are normalized to LF.
*.md text eol=lf
*.yaml text eol=lf
*.yml text eol=lf
*.toml text eol=lf
